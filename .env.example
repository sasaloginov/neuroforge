# PostgreSQL (используется существующий PG из mybot)
DATABASE_URL=postgresql://bot:bot@localhost:5432/neuroforge

# Claude CLI
CLAUDE_MODEL=opus

# Server
PORT=3000

# Manager
MANAGER_INTERVAL_MS=10000
MANAGER_MAX_CONCURRENT=3
MANAGER_ENABLED=true

# Workspace (Docker volume для проектов)
WORKSPACE_DIR=/root/dev
